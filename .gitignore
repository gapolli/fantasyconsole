# =========================================================================
# FantasyConsole - Integrated Version Control Ignore Manifest (.gitignore)
# =========================================================================

# --- Rust Compilation Artifacts & Build Outputs ---
/target/
/debug/
Cargo.lock
cargo-leaves.lock
**/*.rs.bk

# --- Commit Isolation Rules (Explicit Media & Sandbox Exclusion) ---
# Strictly block the entire examples workspace directory from being staged
/examples/

# Globally ignore loose script assets, cartridge buffers, and screenshots
*.p8
*.tic
*.lua
*.png

# --- Test Fixtures Rules ---
tests/fixtures/*.p8
!tests/fixtures/.gitkeep

# --- Environment & Configuration Secrets ---
.env
.env.local
.vscode/
.idea/

# --- System, Backup & OS Files ---
.DS_Store
Thumbs.db
*~

# --- Temporary & Local Editor Buffers ---
tmp/
*.tmp
*.log
*.swp
*.swo
